# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
OWNER_ID=123456789

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./shopbot.db

# Production (PostgreSQL) — uncomment and fill:
# DATABASE_URL=postgresql+asyncpg://shopbot_user:password@localhost:5432/shopbot

# ── Store ─────────────────────────────────────────────────────────────────────
UPI_ID=yourstore@upi
UPI_NAME=My Store
STORE_NAME=🛍 My Store
SUPPORT_USERNAME=@yoursupport

# ── Order Settings ────────────────────────────────────────────────────────────
ORDER_EXPIRY_MINUTES=10
MAX_PENDING_ORDERS=3

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
